{
  "biome.lsp.trace.server": "messages",
  "biome.requireConfiguration": true,
  "breadcrumbs.enabled": false,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.cpp.enablePartialAccepts": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.codeActionsOnSave": {
    "source.action.noDuplicateClasses.biome": "explicit",
    "source.fixAll.oxc": "always",
    "source.sort.json": "explicit"
  },
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 12,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.insertSpaces": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.quickSuggestions": {
    "comments": "inline",
    "other": "inline",
    "strings": "inline"
  },
  "editor.renderLineHighlight": "gutter",
  "editor.renderWhitespace": "trailing",
  "editor.rulers": [
    120,
    80
  ],
  "editor.semanticHighlighting.enabled": true,
  "editor.tabSize": 2,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.js": "${capture}.js.map, ${capture}.d.ts",
    "*.ts": "${capture}.test.ts, ${capture}.spec.ts",
    "*.tsx": "${capture}.test.ts, ${capture}.test.tsx, ${capture}.spec.ts, ${capture}.spec.tsx, ${capture}.stories.tsx",
    "Dockerfile": ".dockerignore",
    "next.config.*s": "next-env.d.ts, postcss.config.*js",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lock",
    "prettier.config.*js": ".prettierignore",
    "tsconfig.json": "tsconfig.*.json"
  },
  "explorer.incrementalNaming": "smart",
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    ".dockerignore": "ignore",
    ".sequelizerc": "javascript",
    "*.css": "tailwindcss",
    "*.h": "c",
    "**/requirements{/**,*}.{txt,in}": "pip-requirements",
    "complex": "c"
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.next/**": true,
    "**/.next/dev/types/**": false,
    "**/.next/types/**": false,
    "**/.turbo/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/storybook-static/**": true
  },
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git.closeDiffOnOperation": true,
  "git.confirmSync": false,
  "git.mergeEditor": true,
  "git.openRepositoryInParentFolders": "always",
  "git.replaceTagsWhenPull": true,
  "git.suggestSmartCommit": false,
  "git.terminalGitEditor": true,
  "git.untrackedChanges": "mixed",
  "github.gitProtocol": "ssh",
  "html.format.preserveNewLines": false,
  "html.format.templating": true,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.enable": true,
  "material-icon-theme.folders.theme": "specific",
  "oxc.requireConfig": true,
  "playwright.reuseBrowser": false,
  "redhat.telemetry.enabled": true,
  "scm.defaultViewMode": "tree",
  "search.defaultViewMode": "tree",
  "search.smartCase": true,
  "security.workspace.trust.untrustedFiles": "open",
  "tailwindCSS.classAttributes": [
    "classNames?",
    ".*ClassNames?"
  ],
  "tailwindCSS.classFunctions": [
    "cn",
    "cva",
    "clsx",
    "tv",
    "twMerge"
  ],
  "tailwindCSS.codeActions": true,
  "tailwindCSS.colorDecorators": true,
  "tailwindCSS.validate": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "line",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.hideOnStartup": "whenEmpty",
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.tabs.hideCondition": "never",
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "update.mode": "manual",
  "window.confirmSaveUntitledWorkspace": false,
  "window.titleBarStyle": "native",
  "workbench.editor.customLabels.patterns": {
    "**/app/**/layout.tsx": "${dirname} - Layout",
    "**/app/**/page.tsx": "${dirname} - Page",
    "**/index.ts": "${dirname} - index",
    "**/index.tsx": "${dirname} - index"
  },
  "workbench.editor.limit.enabled": true,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none"
}
